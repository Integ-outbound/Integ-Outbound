DATABASE_URL=postgresql://user:password@127.0.0.1:5432/integ
ANTHROPIC_API_KEY=
PORT=3000
VERIFICATION_PROVIDER=millionverifier
VERIFICATION_API_KEY=
INTERNAL_API_KEY=replace-with-a-long-random-secret-of-at-least-32-characters
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/mailboxes/google/oauth/callback
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.modify
FRONTEND_BASE_URL=http://localhost:3001
# Required dedicated secret for Gmail refresh-token encryption.
# Do not reuse INTERNAL_API_KEY here.
MAILBOX_TOKEN_ENCRYPTION_KEY=
START_WORKER=true
NODE_ENV=development

# Production targets:
# FRONTEND_BASE_URL=https://integ-outbound.com
# GOOGLE_REDIRECT_URI=https://api.integ-outbound.com/api/v1/mailboxes/google/oauth/callback
