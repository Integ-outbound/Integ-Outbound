BACKEND_API_URL=http://localhost:3000
INTERNAL_API_KEY=replace-with-the-same-internal-api-key-used-by-the-backend
FRONTEND_BASE_URL=http://localhost:3001
FRONTEND_SESSION_SECRET=replace-with-a-long-random-frontend-session-secret
OPERATOR_USERNAME=replace-with-operator-username
OPERATOR_PASSWORD=replace-with-operator-password

