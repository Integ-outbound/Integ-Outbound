{
  "name": "integ-outbound-ops-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:api": "tsx src/index.ts",
    "dev:web": "npm run dev --workspace apps/web",
    "worker": "tsx src/queue/worker.ts",
    "worker:prod": "node dist/queue/worker.js",
    "build:api": "tsc -p tsconfig.json",
    "build:web": "npm run build --workspace apps/web",
    "build": "npm run build:api && npm run build:web",
    "start": "node dist/index.js",
    "start:web": "npm run start --workspace apps/web",
    "test:api": "node --test dist/tests/*.test.js",
    "test": "npm run build && npm run test:api",
    "typecheck:api": "tsc -p tsconfig.json --noEmit",
    "typecheck:web": "npm run typecheck --workspace apps/web",
    "typecheck": "npm run typecheck:api && npm run typecheck:web",
    "readiness:check": "node scripts/readiness-check.mjs",
    "mailboxes:smoke": "node scripts/mailboxes-google-smoke.mjs",
    "import:companies": "tsx src/cli/import-companies.ts",
    "import:contacts": "tsx src/cli/import-contacts.ts",
    "import:status": "tsx src/cli/import-status.ts",
    "import:preflight": "tsx src/cli/import-preflight.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^153.0.0",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "ffmpeg-static": "^5.3.0",
    "puppeteer-core": "^24.42.0",
    "tsx": "^4.19.2",
    "typescript": "5.7.2"
  }
}
